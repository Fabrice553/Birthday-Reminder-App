{
  "name": "birthday-reminder-app",
  "version": "1.0.0",
  "description": "Automated Birthday Reminder Application with cron jobs and email notifications",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "test": "jest --testEnvironment=node --forceExit --maxWorkers=1",
    "docker:build": "docker build -t birthday-reminder-app .",
    "docker:run": "docker run -p 3000:3000 birthday-reminder-app",
    "docker:compose": "docker-compose up -d"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "cors": "^2.8.5",
    "cron": "^1.8.2",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "joi": "^17.9.2",
    "mongoose": "^7.0.0",
    "nodemailer": "^6.9.1"
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "mongodb-memory-server": "^8.12.0",
    "nodemon": "^2.0.22"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}